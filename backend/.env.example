# Exemplo de configurações de desenvolvimento
# Copie este arquivo para .env e ajuste os valores

# Swagger (true em dev, false em prod)
SWAGGER_ENABLED=true

# Nível de log (DEBUG em dev, INFO em prod)
LOG_LEVEL=DEBUG

# Mostrar SQL queries (true em dev, false em prod)
SHOW_SQL=true

# JWT Secret (GERE UM NOVO EM PRODUÇÃO!)
# JWT_SECRET=seu-secret-aqui

# CORS (adicione suas URLs)
# CORS_ORIGINS=http://localhost:5173,https://seu-site.com
